{
  "version": "0.2",
  "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/cspell.schema.json",
  "language": "en",
  "enableGlobDot": true,
  "allowCompoundWords": true,
  "dictionaries": [
    "typescript",
    "node",
    "npm",
    "html",
    "css",
    "bash",
    "en-us",
    "companies",
    "misc"
  ],
  "dictionaryDefinitions": [
    {
      "name": "project-words",
      "path": "./project-words.txt",
      "addWords": true
    }
  ],
  "words": [
    "Jarvis",
    "orchestrator",
    "llms",
    "Groq",
    "pgvector",
    "arxiv",
    "Nandish",
    "nextjs",
    "tailwindcss",
    "postcss",
    "autoprefixer",
    "biomejs",
    "cspell",
    "zod",
    "turbopack",
    "unrs",
    "hackernews",
    "gmail",
    "gcal",
    "pomodoro",
    "macros",
    "openai",
    "embeddings",
    "vectorstore",
    "esnext",
    "esmoduleinterop",
    "middlewares",
    "typedef",
    "instanceof",
    "typeof",
    "keyof",
    "readonly",
    "mixin",
    "getters",
    "setters",
    "destructuring"
  ],
  "ignoreWords": ["gsk", "NEXTAUTH", "POSTHOG", "vercel"],
  "ignorePaths": [
    "node_modules/**",
    ".next/**",
    "out/**",
    "dist/**",
    "build/**",
    "*.min.js",
    "*.min.css",
    "pnpm-lock.yaml",
    "package-lock.json",
    ".git/**",
    "*.log",
    ".env*",
    "*.svg",
    "*.png",
    "*.jpg",
    "*.jpeg",
    "*.gif",
    "*.ico",
    "*.woff",
    "*.woff2",
    "*.ttf",
    "*.eot"
  ],
  "patterns": [
    {
      "name": "Inline disable",
      "pattern": "cspell:disable-line",
      "description": "Ignore the line"
    },
    {
      "name": "UUID",
      "pattern": "/[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}/gi",
      "description": "UUID pattern"
    },
    {
      "name": "hex colors",
      "pattern": "/#[0-9a-fA-F]{3,8}/g",
      "description": "Hex colors"
    },
    {
      "name": "base64",
      "pattern": "/(?:[A-Za-z0-9+/]{4})*(?:[A-Za-z0-9+/]{2}==|[A-Za-z0-9+/]{3}=)?/g",
      "description": "Base64 encoded strings"
    }
  ],
  "overrides": [
    {
      "filename": "**/*.{json,jsonc}",
      "allowCompoundWords": true
    },
    {
      "filename": "**/*.md",
      "allowCompoundWords": true
    }
  ]
}

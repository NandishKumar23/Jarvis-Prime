# -----------------------------------------------------------------------------
# Google ADK / Gemini Configuration (REQUIRED)
# -----------------------------------------------------------------------------
# Powers the orchestrator router and all domain agents, built with Google's
# Agent Development Kit on Gemini. Get a free key from Google AI Studio:
# https://aistudio.google.com/app/apikey
# Free-tier Flash models are sufficient.
GEMINI_API_KEY=your_gemini_api_key_here

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
# The base URL of your application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Node environment (automatically set by Next.js)
NODE_ENV=development

# -----------------------------------------------------------------------------
# Optional: Future Integrations (Not yet implemented)
# -----------------------------------------------------------------------------
# OpenAI API for embeddings
# OPENAI_API_KEY=sk_your_openai_key_here

# PostgreSQL database with pgvector
# DATABASE_URL=postgresql://user:password@localhost:5432/jarvis_prime

# -----------------------------------------------------------------------------
# Development Options
# -----------------------------------------------------------------------------
# Skip environment validation (useful for Docker builds)
# SKIP_ENV_VALIDATION=true

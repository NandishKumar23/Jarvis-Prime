{
  "name": "jarvis-prime",
  "version": "1.0.0",
  "description": "AI orchestrator with domain-specific agents",
  "private": true,
  "author": "NandishKumar23",
  "license": "MIT",
  "packageManager": "pnpm@10.24.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "check:ci": "pnpm check:format && pnpm check:lint",
    "check:unused-code": "knip",
    "check:format": "biome format .",
    "check:lint": "biome lint .",
    "format": "biome format --write .",
    "lint": "biome lint --write .",
    "spell": "cspell \"**/*.{ts,tsx,js,jsx,md,json}\"",
    "spell:fix": "cspell \"**/*.{ts,tsx,js,jsx,md,json}\" --show-suggestions",
    "type-check": "tsc --noEmit",
    "check:spelling": "cspell \"**/*.{md,txt,ts,tsx,js,jsx}\"",
    "validate": "pnpm type-check && pnpm check:ci && pnpm spell"
  },
  "dependencies": {
    "@google/adk": "^1.3.0",
    "@t3-oss/env-nextjs": "^0.13.11",
    "next": "^16.2.6",
    "next-auth": "5.0.0-beta.31",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "autoprefixer": "^10.5.0",
    "cspell": "^10.0.0",
    "eslint": "^10.3.0",
    "eslint-config-next": "^16.2.6",
    "knip": "^6.27.0",
    "postcss": "^8.5.14",
    "postcss-load-config": "^6.0.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3"
  }
}
